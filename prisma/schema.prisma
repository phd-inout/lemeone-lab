// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}



// ============================================================
// User — 玩家账号
// ============================================================
model User {
  id        String   @id
  email     String   @unique
  username  String?
  tier      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rehearsals Rehearsal[]
  projects   Project[]
}

// ============================================================
// Project — 商业案卷 / 项目集
// ============================================================
model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  rehearsals  Rehearsal[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// Rehearsal — 每一局模拟的完整记录 (2.0 商业重力沙盒版)
// ============================================================
model Rehearsal {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 14 维产品向量快照 (14D Vector)
  productVector String

  // 模拟设置
  populationSize Int @default(100) // 100 for FREE, 10000 for PRO, 100000 for ENTERPRISE

  // 战略资产 (Strategic Assets) - 存储生成的 Markdown 内容
  // 包含: PROPOSAL, BACKLOG, MARKET_FEEDBACK, STRESS_TEST_REPORT
  assets String @default("{}")

  // 模拟运行数据
  cash         Float @default(100000)
  techDebt     Float @default(0)
  weekNumber   Int   @default(0)
  currentStage String @default("SEED")

  // 历史快照记录 (JOURNAL.md 的数据源)
  historyJson String @default("[]")

  // 结局
  isFailed      Boolean @default(false)
  failureReason String?

  productLines ProductLine[]
}

// ============================================================
// ProductLine — 多产品线管理
// ============================================================
model ProductLine {
  id               String @id @default(uuid())
  rehearsalId      String
  name             String?
  industry         String
  
  // 14 维产品向量
  vector String

  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
}
